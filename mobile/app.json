{
  "expo": {
    "name": "Ajo",
    "slug": "ajo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ajo.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely authenticate",
        "NSCameraUsageDescription": "Used for QR code scanning and profile pictures",
        "NSPhotoLibraryUsageDescription": "Used to select profile pictures"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "package": "com.ajo.mobile",
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366f1"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to securely authenticate"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Ajo to access your camera for QR scanning"
        }
      ]
    ],
    "scheme": "ajo",
    "experiments": {
      "typedRoutes": true
    }
  }
}
