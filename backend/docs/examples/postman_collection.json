{
  "info": {
    "name": "Ajo API",
    "description": "Complete Ajo API collection. Set the `baseUrl` and `token` variables before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "token", "value": "" },
    { "key": "groupId", "value": "group_abc123" },
    { "key": "goalId", "value": "goal_001" },
    { "key": "disputeId", "value": "disp_001" },
    { "key": "publicKey", "value": "GABC...XYZ" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"publicKey\": \"{{publicKey}}\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Groups",
      "item": [
        {
          "name": "List Groups",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/groups?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Group",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/groups/{{groupId}}"
          }
        },
        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/groups",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monthly Savers\",\n  \"contributionAmount\": 500000000,\n  \"frequency\": 30,\n  \"maxMembers\": 10\n}"
            }
          }
        },
        {
          "name": "Join Group",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/groups/{{groupId}}/join",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"walletAddress\": \"{{publicKey}}\"}"
            }
          }
        },
        {
          "name": "Contribute",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/groups/{{groupId}}/contribute",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 500000000, \"txHash\": \"abc123\"}"
            }
          }
        },
        {
          "name": "Get Members",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/groups/{{groupId}}/members"
          }
        },
        {
          "name": "Get Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/groups/{{groupId}}/transactions"
          }
        }
      ]
    },
    {
      "name": "Goals",
      "item": [
        {
          "name": "List Goals",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/goals",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Goal",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/goals",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Emergency Fund\",\n  \"category\": \"EMERGENCY\",\n  \"targetAmount\": 10000000000,\n  \"deadline\": \"2026-12-31T00:00:00.000Z\",\n  \"isPublic\": false\n}"
            }
          }
        },
        {
          "name": "Affordability Check",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/goals/affordability",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetAmount\": 10000000000,\n  \"deadline\": \"2026-12-31T00:00:00.000Z\",\n  \"monthlyIncome\": 5000000000,\n  \"monthlyExpenses\": 3000000000\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Gamification",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/gamification/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/gamification/leaderboard?limit=10",
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        },
        {
          "name": "Track Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/gamification/login",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Challenges",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/gamification/challenges"
          }
        }
      ]
    },
    {
      "name": "Referrals",
      "item": [
        {
          "name": "Generate Code",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/referrals/generate",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Validate Code",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/referrals/validate",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"code\": \"AJO-XYZ123\"}"
            }
          }
        },
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/referrals/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Disputes",
      "item": [
        {
          "name": "File Dispute",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/disputes",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{groupId}}\",\n  \"type\": \"non_payment\",\n  \"summary\": \"Member has not contributed for 2 cycles\",\n  \"evidence\": [{\"type\": \"text\", \"content\": \"No payment since Jan 2026\"}]\n}"
            }
          }
        },
        {
          "name": "Get Dispute",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/disputes/{{disputeId}}"
          }
        },
        {
          "name": "Vote on Dispute",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/disputes/{{disputeId}}/vote",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"vote\": \"in_favor\"}"
            }
          }
        }
      ]
    },
    {
      "name": "KYC",
      "item": [
        {
          "name": "Get Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/kyc/status",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Request Verification",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/kyc/request",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/kyc/upload",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"docType\": \"passport\", \"data\": \"base64encodeddata...\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Track Event",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/analytics",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"type\": \"page_view\", \"userId\": \"{{publicKey}}\", \"eventData\": {\"page\": \"/groups\"}}"
            }
          }
        },
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/analytics/stats"
          }
        },
        {
          "name": "Create Export",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/analytics/export",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"format\": \"csv\",\n  \"dateRange\": {\"start\": \"2026-01-01T00:00:00.000Z\", \"end\": \"2026-03-31T00:00:00.000Z\"},\n  \"includeMetrics\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    }
  ]
}
